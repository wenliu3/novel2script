# novel2script 环境变量配置
# 复制此文件为 .env 并填入你的 API 密钥

# LLM API 密钥（必需）
MILM_API_KEY=your-api-key-here

# LLM API 端点地址（OpenAI 兼容接口）
MILM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# 模型名称
MILM_MODEL=mimo-v2.5

# 生成参数（可选）
# TEMPERATURE=0.7
# MAX_TOKENS=16000

# 切块大小（可选，默认 100000 字符）
# CHUNK_SIZE=100000

# 输出目录（可选，默认 output）
# OUTPUT_BASE=output
