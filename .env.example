# novel2script 环境变量配置
# 复制此文件为 .env 并填入你的 API 密钥

# MiLM (小米大模型) API 密钥（必需）
MILM_API_KEY=your-milm-api-key-here

# MiLM API 端点地址（OpenAI 兼容接口）
MILM_BASE_URL=https://api.xiaomi.com/v1

# MiLM 模型名称
MILM_MODEL=milm

# 生成参数（可选）
# TEMPERATURE=0.7
# MAX_TOKENS=4096
# RETRY_TIMES=3
# RETRY_WAIT=1.0

# 输出目录（可选）
# OUTPUT_BASE=output
